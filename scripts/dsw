#!/usr/bin/env bash
# dsw — "docker swift wrapper". Canonical way to build/test the Swift tree.
#
# All Swift build/test for wendyos-update runs inside the Linux aarch64
# toolchain container (libzstd/zlib, LinuxSys ioctls, and musl are not
# buildable on macOS). Named volumes cache SwiftPM's dependency checkouts
# and build products across invocations so repeated runs are fast.
#
# Usage:
#   scripts/dsw test               # swift test
#   scripts/dsw build -c release   # swift build
#   scripts/dsw <any swift args>
set -euo pipefail
IMG="${WOS_SWIFT_IMAGE:-swiftlang/swift:nightly-6.3-jammy}"
REPO="$(cd "$(dirname "$0")/.." && pwd)"
[ -d "$REPO/swift" ] || { echo "dsw: $REPO/swift does not exist yet" >&2; exit 2; }
exec docker run --rm \
  -v "$REPO/swift:/w" -w /w \
  -v wos-swift-build:/w/.build \
  -v wos-swift-cache:/root/.cache \
  -v wos-swift-pm:/root/.swiftpm \
  "$IMG" swift "$@"
